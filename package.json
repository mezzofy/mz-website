{
  "name": "mezzofy-landing-page",
  "version": "1.0.0",
  "description": "Mezzofy - Global Coupon Exchange Protocol Landing Page",
  "scripts": {
    "dev": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
    "build": "tailwindcss -i ./src/input.css -o ./dist/output.css --minify && npm run copy-i18n && npm run copy-js",
    "copy-i18n": "cp -r src/i18n dist/",
    "copy-js": "mkdir -p dist/js && cp src/js/*.js dist/js/",
    "upload": "aws s3 sync dist/ s3://mz-website-v3/release-v3/ --delete",
    "deploy": "npm run upload && ./scripts/deploy-amplify.sh"
  },
  "keywords": [
    "mezzofy",
    "tailwind",
    "landing-page"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "shadcn": "^3.6.0",
    "tailwindcss": "^3.4.0"
  }
}
